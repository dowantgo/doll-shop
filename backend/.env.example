# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Configuration
DB_NAME=shop
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379/0

# Email Configuration
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your@qq.com
EMAIL_HOST_PASSWORD=your-smtp-auth-code
DEFAULT_FROM_EMAIL=your@qq.com

# Alipay Configuration
# Use ALIPAY_APP_ID as the canonical key.
# (Backend is backward-compatible with ALIPAY_APPID.)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://localhost:8000/api/pay/notify/alipay/
ALIPAY_RETURN_URL=http://localhost:5173/orders
ALIPAY_DEBUG=True

# WeChat Configuration
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=http://localhost:8000/api/pay/notify/wechat/
WECHAT_DEBUG=True

# Payment Feature Toggles
MOCK_PAYMENT_ENABLED=True
PAYMENT_EXPIRE_MINUTES=30
