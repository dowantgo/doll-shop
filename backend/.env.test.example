# Django
SECRET_KEY=test-secret-key
DEBUG=True

# Database Configuration
# 建议测试人员使用独立测试库，避免污染开发库
DB_NAME=shop_test
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis Configuration
# 建议使用独立 DB 序号，避免与日常开发缓存混用
REDIS_URL=redis://127.0.0.1:6379/1

# Email Configuration
# 本地测试可先保留占位；若不测真实邮箱验证码，可由开发提供测试开关或测试账号
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=test@example.com
EMAIL_HOST_PASSWORD=your-smtp-auth-code
DEFAULT_FROM_EMAIL=test@example.com

# Alipay Configuration
# 日常回归优先使用 mock 支付；真实联调时再替换为公网地址
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://127.0.0.1:8000/api/pay/notify/alipay/
ALIPAY_RETURN_URL=http://127.0.0.1:5173/orders
ALIPAY_DEBUG=True

# WeChat Configuration
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=http://127.0.0.1:8000/api/pay/notify/wechat/
WECHAT_DEBUG=True

# Payment Feature Toggles
MOCK_PAYMENT_ENABLED=True
PAYMENT_EXPIRE_MINUTES=30

