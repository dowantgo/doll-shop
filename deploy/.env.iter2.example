# Iteration 2 local test stack (Docker Compose)
# Copy to deploy/.env.iter2 before startup.

# -----------------------------
# Port mapping (host -> container)
# -----------------------------
FRONTEND_PORT=5173
BACKEND_PORT=8000
MYSQL_PORT=3307
REDIS_PORT=6380

# -----------------------------
# Backend app
# -----------------------------
SECRET_KEY=iter2-dev-only-change-me
DEBUG=True
PRODUCT_FEED_CACHE_TTL=120
INIT_DATA_ON_START=1
MOCK_PAYMENT_ENABLED=True

# Browser-side API address.
# Keep this pointing to host backend port when using local Docker.
VITE_API_BASE_URL=http://127.0.0.1:8000/api/

# -----------------------------
# MySQL
# -----------------------------
MYSQL_DATABASE=shop_iter2
MYSQL_USER=shop_user
MYSQL_PASSWORD=shop_pass_123
MYSQL_ROOT_PASSWORD=root_pass_123

# -----------------------------
# Alipay (optional for callback联调)
# -----------------------------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=http://127.0.0.1:8000/api/pay/notify/alipay/
ALIPAY_RETURN_URL=http://127.0.0.1:5173/orders
ALIPAY_DEBUG=True

# -----------------------------
# SMTP (optional)
# -----------------------------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
